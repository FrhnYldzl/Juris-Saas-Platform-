# ============================================================
# Juris Platform — Environment Variables (Template)
# Copy to .env.local for local dev, configure in Railway for prod
# ============================================================

# --- Core ---
NODE_ENV=development
NEXT_PUBLIC_APP_URL=http://localhost:3000
PORT=3000

# --- Database (Railway Postgres) ---
DATABASE_URL="postgresql://postgres:password@localhost:5432/juris?schema=public"

# --- Auth ---
# Generate with: openssl rand -base64 32
AUTH_SECRET="change-me-to-a-long-random-string"
AUTH_URL=http://localhost:3000
# Optional: Set to "true" to disable public signup (invite-only mode)
AUTH_SIGNUP_DISABLED=false

# --- Admin bootstrap (used once on first deploy) ---
# The first user created on an empty DB becomes the firm owner.
BOOTSTRAP_FIRM_NAME="Juris Hukuk Bürosu"
BOOTSTRAP_ADMIN_EMAIL=admin@juris.local
BOOTSTRAP_ADMIN_PASSWORD=change-me-on-first-login

# --- AI Providers ---
# Set the ones you want active. Missing keys disable the provider.
ANTHROPIC_API_KEY=
OPENAI_API_KEY=
GOOGLE_AI_API_KEY=
XAI_API_KEY=
MISTRAL_API_KEY=
COHERE_API_KEY=
# Default provider for general chat/drafting ("anthropic" | "openai" | "gemini")
AI_DEFAULT_PROVIDER=anthropic

# --- Turkish Legal Integrations (stubs for now) ---
UYAP_USERNAME=
UYAP_PASSWORD=
UYAP_CERT_PATH=
GIB_USERNAME=
GIB_PASSWORD=
GIB_TEST_MODE=true
MERNIS_USERNAME=
MERNIS_PASSWORD=
LEXPERA_API_KEY=

# --- Google Workspace / Drive (OAuth) ---
GOOGLE_CLIENT_ID=
GOOGLE_CLIENT_SECRET=

# --- Storage ---
# "local" uses ./storage (Railway volume), "s3" uses S3-compatible
STORAGE_DRIVER=local
STORAGE_LOCAL_PATH=./storage
S3_ENDPOINT=
S3_REGION=
S3_BUCKET=
S3_ACCESS_KEY=
S3_SECRET_KEY=

# --- Observability ---
SENTRY_DSN=
SENTRY_ENVIRONMENT=development
LOG_LEVEL=info

# --- Feature Flags ---
FEATURE_AI_ENABLED=true
FEATURE_CLIENT_PORTAL_ENABLED=true
